                    transparent 0px, transparent 14px,
                    var(--dt-line) 14px, var(--dt-line) 16px
                ),
                repeating-linear-gradient(
                    -45deg,
                    transparent 0px, transparent 14px,
                    var(--dt-line) 14px, var(--dt-line) 16px
                );
            color: var(--text);
        }

        /* loading screen — simple centred layout, no fragmented fake window */
        #transfer {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            gap: 10px;
        }

        /* suppress the old pseudo-element window frame */
        #transfer::before, #transfer::after { content: none; display: none; }

        #status {
            font-size: 0.9rem;
            color: var(--white);
            text-shadow: 1px 1px 2px rgba(0,0,0,0.6);
            background: transparent;
            border: none;
            padding: 0;
            width: auto;
        }

        #progress {
            -webkit-appearance: none;
            appearance: none;
            display: block;
            width: 340px;
            height: 16px;
            border-top: 1px solid var(--darker);
            border-left: 1px solid var(--darker);
            border-right: 1px solid var(--white);
            border-bottom: 1px solid var(--white);
            background: var(--white);
            overflow: hidden;
        }

        #progress::-webkit-progress-bar   { background: var(--white); }
        #progress::-webkit-progress-value { background: var(--navy); }
        #progress::-moz-progress-bar      { background: var(--navy); }

        /* Win95 dialog window — crisp 1px black outer edge, then 3D border inside */
        #infobox {
            position: fixed;
            background: var(--bg);
            color: var(--text);
            font-weight: normal;
            font-size: 0.85rem;
            text-align: left;
            padding: 0;
            min-width: 300px;
            /* outer black ring separates window from any background */
            box-shadow: 0 0 0 1px #000000;
            /* Win95 raised 3D border */
            border: 2px solid;
            border-color: var(--white) var(--darker) var(--darker) var(--white);
            z-index: 999999;
        }

        /* title bar inside infobox */
        #infobox strong {
            display: block;
            background: linear-gradient(to right, var(--navy), var(--navy2));
            color: var(--white);
            padding: 3px 8px;
            font-size: 0.85rem;
            font-weight: bold;
